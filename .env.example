# === Bot ===
TELEGRAM_TOKEN=
TELEGRAM_OLD_TOKEN=

# === Database ===
# Desenvolvimento (SQLite)
DATABASE_LOCAL_PATH=finance.db
LOCAL_MODE=true

# Produção (PostgreSQL) — usado com docker-compose.prod.yml
# DATABASE_URL=postgresql://financialbot:changeme@db:5432/financial_bot
# LOCAL_MODE=false

# === LLM / Groq ===
LLM_ENABLED=true
LLM_API_KEY=
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# === Other ===
MAX_DATE_INTERVAL=6
